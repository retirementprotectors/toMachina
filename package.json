{
  "name": "tomachina",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/api",
    "services/bigquery-stream",
    "services/bridge",
    "services/intake"
  ],
  "scripts": {
    "postinstall": "bash scripts/link-env.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "migrate": "cd scripts && npx tsx load-clients.ts",
    "migrate:reference": "npx tsx scripts/load-reference.ts",
    "migrate:remaining": "npx tsx scripts/load-remaining.ts",
    "migrate:activities": "npx tsx scripts/load-activities-comms.ts",
    "spot-check": "npx tsx scripts/spot-check.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "pdf-parse": "^2.4.5",
    "pdf-to-img": "^5.0.0",
    "pdfjs-dist": "^5.5.207",
    "turbo": "^2.8.20",
    "typescript": "^5.7.0",
    "xlsx": "^0.18.5",
    "zipcodes": "^8.0.0",
    "zipcodes-nrviens": "^8.0.6",
    "zips": "^1.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "qrcode.react": "^4.2.0"
  }
}
