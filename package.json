{
  "name": "tomachina",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/api",
    "services/bigquery-stream",
    "services/intake",
    "services/webhooks"
  ],
  "scripts": {
    "postinstall": "bash scripts/link-env.sh && bash scripts/sync-service-lockfiles.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "migrate": "cd scripts && npx tsx load-clients.ts",
    "migrate:reference": "npx tsx scripts/load-reference.ts",
    "migrate:remaining": "npx tsx scripts/load-remaining.ts",
    "migrate:activities": "npx tsx scripts/load-activities-comms.ts",
    "spot-check": "npx tsx scripts/spot-check.ts",
    "test:e2e": "vitest run --config tests/e2e/vitest.config.ts",
    "test:e2e:local": "TEST_API_URL=http://localhost:8080 vitest run --config tests/e2e/vitest.config.ts",
    "test:e2e:ui": "npx playwright test --project=setup --project=chromium",
    "test:e2e:seed": "npx tsx tests/e2e/scripts/seed-test-client.ts",
    "test:e2e:pure": "vitest run --config tests/e2e/vitest.pure.config.ts",
    "generate:voltron-registry": "npx tsx scripts/generate-voltron-registry.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@playwright/test": "^1.59.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.1",
    "googleapis": "^171.4.0",
    "pdf-parse": "^2.4.5",
    "pdf-to-img": "^5.0.0",
    "pdfjs-dist": "^5.6.205",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "xlsx": "^0.18.5",
    "zipcodes": "^8.0.0",
    "zipcodes-nrviens": "^8.0.6",
    "zips": "^1.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@twilio/voice-sdk": "^2.18.1",
    "qrcode.react": "^4.2.0"
  }
}
