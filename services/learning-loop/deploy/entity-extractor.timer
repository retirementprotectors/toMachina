# systemd timer for entity extraction — MDJ_SERVER
# System Synergy — ZRD-SYN-007
#
# Deploy to: /etc/systemd/system/entity-extractor.timer
# Then: sudo systemctl daemon-reload && sudo systemctl enable --now entity-extractor.timer

[Unit]
Description=Daily entity extractor (2am)

[Timer]
OnCalendar=*-*-* 02:00:00
Persistent=true
AccuracySec=1min

[Install]
WantedBy=timers.target
