# systemd service for claude-md-writer — MDJ_SERVER
# LL-11 — auto-promote high-confidence knowledge_entries to ~/.claude/CLAUDE.md
#
# Runs AFTER knowledge-promote so both share the same nightly extraction window.
# Deploy to: /etc/systemd/system/claude-md-writer.service
# Then: sudo systemctl daemon-reload && sudo systemctl enable claude-md-writer.timer

[Unit]
Description=RPI Claude MD Writer — Auto-promote knowledge to ~/.claude/CLAUDE.md
After=network-online.target knowledge-promote.service
Wants=network-online.target
OnFailure=slack-alert@%p.service

[Service]
Type=oneshot
User=jdm
WorkingDirectory=/home/jdm/Projects/toMachina/services/learning-loop
Environment="NODE_ENV=production"
Environment="GOOGLE_APPLICATION_CREDENTIALS=/home/jdm/Projects/dojo-warriors/mdj-agent/sa-key.json"
EnvironmentFile=/home/jdm/Projects/dojo-warriors/mdj-agent/.env
ExecStart=/usr/bin/node dist/claude-md-writer.js
StandardOutput=journal
StandardError=journal
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
