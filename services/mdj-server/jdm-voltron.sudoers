# /etc/sudoers.d/jdm-voltron
# Grants jdm passwordless sudo for mdj-agent service restart only.
# Used by POST /webhook/deploy (GitHub auto-deploy webhook).
#
# Install: sudo cp jdm-voltron.sudoers /etc/sudoers.d/jdm-voltron && sudo chmod 440 /etc/sudoers.d/jdm-voltron
# Verify:  sudo visudo -cf /etc/sudoers.d/jdm-voltron
#
# TRK-13856 / TRK-13862

jdm ALL=(ALL) NOPASSWD: /bin/systemctl restart mdj-agent.service
