# Bridge Service Environment Variables
# Copy to .env and fill in values

# GCP Project (defaults to claude-mcp-484718)
GCP_PROJECT_ID=claude-mcp-484718

# MATRIX Spreadsheet IDs — get from RAPID_CORE Script Properties
# or from the spreadsheet URLs directly
RAPID_MATRIX_ID=1nnSY-J3n6DtVvKqyC40zpEt1sROtHkIEqmSwG-5d9dU
PRODASH_MATRIX_ID=
SENTINEL_MATRIX_ID=1K_DLb-txoI4F1dLrUyoFOuFc0xwsH1iW5eff3pQ_o6E

# Server port (defaults to 8081 for local, 8080 for Cloud Run)
PORT=8081

# Auth: Uses Application Default Credentials
# Local: run `gcloud auth application-default login`
# Cloud Run: automatic via service account
