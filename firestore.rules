rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------------
    // Helper functions
    // ----------------------------------------------------------------

    // Authenticated @retireprotected.com users only
    function isRPIUser() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@retireprotected\\.com');
    }

    // Executive or above (level 0 = OWNER, level 1 = EXECUTIVE)
    function isExecutiveOrAbove() {
      return isRPIUser() &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.level <= 1;
    }

    // Leader or above (level 0 = OWNER, level 1 = EXECUTIVE, level 2 = LEADER)
    function isLeaderOrAbove() {
      return isRPIUser() &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.level <= 2;
    }

    // Owner only (level 0)
    function isOwner() {
      return isRPIUser() &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.level == 0;
    }

    // Check if user is modifying their own profile
    function isOwnProfile(email) {
      return isRPIUser() && request.auth.token.email == email;
    }

    // ----------------------------------------------------------------
    // Collection group queries
    // ----------------------------------------------------------------

    // Cross-client account queries
    match /{path=**}/accounts/{docId} {
      allow read: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Users — self-update (restricted fields) + executive full write
    // ----------------------------------------------------------------
    match /users/{email} {
      allow read: if isRPIUser();

      // Users can update their own profile EXCEPT protected fields
      allow update: if isOwnProfile(email) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['level', 'user_level', 'role_template', 'module_permissions', 'status']);

      // Executives can do anything (create, update, delete)
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Org structure — executive only writes
    // ----------------------------------------------------------------
    match /org/{unitId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Portal config — leader+ writes
    // ----------------------------------------------------------------
    match /portal_config/{portal}/{subcol}/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Pipeline Factory — definition collections (leader+ writes)
    // ----------------------------------------------------------------
    match /flow_pipelines/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }
    match /flow_stages/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }
    match /flow_workflows/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }
    match /flow_steps/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }
    match /flow_task_templates/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }

    // ----------------------------------------------------------------
    // Pipelines — top-level pipeline records
    // ----------------------------------------------------------------
    match /pipelines/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Pipeline Factory — instance collections (daily work, all RPI users)
    // ----------------------------------------------------------------
    match /flow_instances/{docId} {
      allow read, write: if isRPIUser();
    }
    match /flow_instance_tasks/{docId} {
      allow read, write: if isRPIUser();
    }
    match /flow_activity/{docId} {
      allow read, write: if isRPIUser();
    }

    // Audit trail — global activity log
    match /activities/{activityId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Households + subcollections (daily work)
    // ----------------------------------------------------------------
    match /households/{householdId} {
      allow read, write: if isRPIUser();
      match /{subcollection}/{docId} {
        allow read, write: if isRPIUser();
      }
    }

    // ----------------------------------------------------------------
    // Clients + subcollections (daily work)
    // ----------------------------------------------------------------
    match /clients/{clientId} {
      allow read, write: if isRPIUser();
      match /{subcollection}/{docId} {
        allow read, write: if isRPIUser();
      }
    }

    // ----------------------------------------------------------------
    // Daily work collections — all RPI users
    // ----------------------------------------------------------------
    // @deprecated — agents collection is being replaced by users (is_agent: true) + producers.
    // Retained during transition for backward compatibility.
    match /agents/{agentId} {
      allow read, write: if isRPIUser();
    }
    // External producers (recruited via DAVID/SENTINEL). Replaces internal entries from agents.
    match /producers/{producerId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /opportunities/{oppId} {
      allow read, write: if isRPIUser();
    }
    match /case_tasks/{taskId} {
      allow read, write: if isRPIUser();
    }
    match /communications/{commId} {
      allow read, write: if isRPIUser();
    }
    match /call_sessions/{sessionId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Revenue, carriers, products — leader+ writes
    // ----------------------------------------------------------------
    match /revenue/{revenueId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isLeaderOrAbove();
    }
    match /carriers/{carrierId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /products/{productId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Learning Loop — Session Intelligence (Sprint 003)
    // ----------------------------------------------------------------
    match /knowledge_entries/{entryId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }
    match /dojo_warriors/{warriorId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Campaign engine — leader+ writes
    // ----------------------------------------------------------------
    match /campaigns/{campaignId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /templates/{templateId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /content_blocks/{blockId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    // C3 operational collections — send logs, delivery tracking, enrollments
    match /campaign_send_log/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /campaign_delivery_events/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /campaign_enrollments/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /drip_sequences/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /campaign_schedules/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /campaign_jobs/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /queued_sends/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Comp grids — executive only writes
    // ----------------------------------------------------------------
    match /comp_grids/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Flow (legacy) — daily work
    // ----------------------------------------------------------------
    match /flow/{subcol}/{docId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // ATLAS — source + tool registries (top-level collections)
    // Aligned with ATLAS module minUserLevel: EXECUTIVE
    // ----------------------------------------------------------------
    match /source_registry/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }
    match /tool_registry/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }
    match /atlas_audit/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // ATLAS — subcollections (formats, introspect_runs)
    // ----------------------------------------------------------------
    match /atlas/{subcol}/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // FORGE — Build Tracker
    // Read: any RPI user (Report Button is universal, leaders see the board)
    // Write: owner only (sprint/item management is JDM-only for now)
    // ----------------------------------------------------------------
    match /tracker_items/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }
    match /sprints/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }

    // ----------------------------------------------------------------
    // ProZone — Territories + Specialist Configs
    // Read: any RPI user (specialists view their own config)
    // Write: owner only (territory/specialist admin is JDM-only)
    // ----------------------------------------------------------------
    match /territories/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }
    match /specialist_configs/{docId} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }

    // ----------------------------------------------------------------
    // Notifications — activity feed (all RPI users)
    // ----------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Approval queue — import/data approvals (leader+ only)
    // ----------------------------------------------------------------
    match /approval_queue/{docId} {
      allow read: if isLeaderOrAbove();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // CAM operational — commission discrepancies + comp grid history
    // ----------------------------------------------------------------
    match /commission_discrepancies/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }
    match /comp_grid_history/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // DEX — Document Efficiency Xelerator (forms, mappings, rules, kits, packages)
    // ----------------------------------------------------------------
    match /dex_forms/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /dex_field_mappings/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /dex_rules/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /dex_kits/{docId} {
      allow read: if isRPIUser();
      allow write: if isRPIUser();
    }
    match /dex_packages/{docId} {
      allow read: if isRPIUser();
      allow write: if isRPIUser();
      match /{subcollection}/{subDocId} {
        allow read: if isRPIUser();
        allow write: if isRPIUser();
      }
    }
    match /dex_package_events/{docId} {
      allow read: if isRPIUser();
      allow write: if isRPIUser();
    }
    match /taxonomy_carriers/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /taxonomy_products/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /taxonomy_account_types/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /taxonomy_transactions/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Communications log — structured send/receive history
    // ----------------------------------------------------------------
    match /communication_log/{docId} {
      allow read: if isLeaderOrAbove();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Compliance + Security — workspace users, audit records
    // ----------------------------------------------------------------
    match /workspace_users/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }
    match /compliance_audits/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Unit module defaults — Firestore-driven config for unit→module mapping
    // ----------------------------------------------------------------
    match /unit_module_defaults/{unitKey} {
      allow read: if isRPIUser();
      allow write: if isOwner();
    }

    // ----------------------------------------------------------------
    // Account dedup — split account collections (life, investments)
    // ----------------------------------------------------------------
    match /accounts_life/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /accounts_investments/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // GUARDIAN — Data Protection Engine
    // ----------------------------------------------------------------
    match /guardian_audits/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }
    match /guardian_findings/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }
    match /data_snapshots/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }
    match /guardian_writes/{docId} {
      allow read: if isExecutiveOrAbove();
      allow write: if isExecutiveOrAbove();
    }
    match /anomaly_alerts/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // RPI Connect — channels for team communication
    // ----------------------------------------------------------------
    match /connect_channels/{channelId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Intake + Wire — pipeline processing collections
    // ----------------------------------------------------------------
    match /intake_queue/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /intake_config/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /voltron_registry/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /wire_executions/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /taxonomy_misses/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /learning_library/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /email_inbox_config/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Approval batches — used by Notifications APPROVALS tab (browser reads)
    // ----------------------------------------------------------------
    match /approval_batches/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // ACF Config — admin-only write, all RPI users read
    // ----------------------------------------------------------------
    match /acf_config/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // Document Taxonomy — document type definitions for ACF routing
    // ----------------------------------------------------------------
    match /document_taxonomy/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // Document Link Config — rules mapping doc types to UI locations
    // ----------------------------------------------------------------
    match /document_link_config/{docId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // Document Index — cached metadata for fast UI retrieval
    // ----------------------------------------------------------------
    match /document_index/{docId} {
      allow read: if isRPIUser();
      allow write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // MDJ — MyDigitalJosh AI assistant collections
    // ----------------------------------------------------------------
    match /mdj_conversations/{convId} {
      allow read: if isRPIUser() && resource.data.user_email == request.auth.token.email;
      allow create: if isRPIUser();
      allow update: if isRPIUser() && resource.data.user_email == request.auth.token.email;
    }
    match /mdj_conversations/{convId}/messages/{msgId} {
      allow read, write: if isRPIUser();
    }
    match /mdj_client_insights/{clientId} {
      allow read, write: if isRPIUser();
    }
    match /mdj_specialist_configs/{configId} {
      allow read: if isRPIUser();
      allow write: if request.auth.token.email in ['josh@retireprotected.com', 'john@retireprotected.com'];
    }
  }
}
