rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------------
    // Helper functions
    // ----------------------------------------------------------------

    // Authenticated @retireprotected.com users only
    function isRPIUser() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@retireprotected\\.com');
    }

    // Executive or above (level 0 = OWNER, level 1 = EXECUTIVE)
    function isExecutiveOrAbove() {
      return isRPIUser() &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.level <= 1;
    }

    // Leader or above (level 0 = OWNER, level 1 = EXECUTIVE, level 2 = LEADER)
    function isLeaderOrAbove() {
      return isRPIUser() &&
             get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.level <= 2;
    }

    // Check if user is modifying their own profile
    function isOwnProfile(email) {
      return isRPIUser() && request.auth.token.email == email;
    }

    // ----------------------------------------------------------------
    // Collection group queries
    // ----------------------------------------------------------------

    // Cross-client account queries
    match /{path=**}/accounts/{docId} {
      allow read: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Users — self-update (restricted fields) + executive full write
    // ----------------------------------------------------------------
    match /users/{email} {
      allow read: if isRPIUser();

      // Users can update their own profile EXCEPT protected fields
      allow update: if isOwnProfile(email) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['level', 'user_level', 'role_template', 'module_permissions', 'status']);

      // Executives can do anything (create, update, delete)
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Org structure — executive only writes
    // ----------------------------------------------------------------
    match /org/{unitId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Portal config — leader+ writes
    // ----------------------------------------------------------------
    match /portal_config/{portal}/{subcol}/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Pipeline Factory — definition collections (leader+ writes)
    // ----------------------------------------------------------------
    match /flow_pipelines/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /flow_stages/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /flow_workflows/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /flow_steps/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /flow_task_templates/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Pipeline Factory — instance collections (daily work, all RPI users)
    // ----------------------------------------------------------------
    match /flow_instances/{docId} {
      allow read, write: if isRPIUser();
    }
    match /flow_instance_tasks/{docId} {
      allow read, write: if isRPIUser();
    }
    match /flow_activity/{docId} {
      allow read, write: if isRPIUser();
    }

    // Audit trail — global activity log
    match /activities/{activityId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Clients + subcollections (daily work)
    // ----------------------------------------------------------------
    match /clients/{clientId} {
      allow read, write: if isRPIUser();
      match /{subcollection}/{docId} {
        allow read, write: if isRPIUser();
      }
    }

    // ----------------------------------------------------------------
    // Daily work collections — all RPI users
    // ----------------------------------------------------------------
    match /agents/{agentId} {
      allow read, write: if isRPIUser();
    }
    match /producers/{producerId} {
      allow read, write: if isRPIUser();
    }
    match /opportunities/{oppId} {
      allow read, write: if isRPIUser();
    }
    match /case_tasks/{taskId} {
      allow read, write: if isRPIUser();
    }
    match /communications/{commId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // Revenue, carriers, products — leader+ writes
    // ----------------------------------------------------------------
    match /revenue/{revenueId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /carriers/{carrierId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /products/{productId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Campaign engine — leader+ writes
    // ----------------------------------------------------------------
    match /campaigns/{campaignId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /templates/{templateId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /content_blocks/{blockId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // Comp grids — executive only writes
    // ----------------------------------------------------------------
    match /comp_grids/{type}/{gridId} {
      allow read: if isRPIUser();
      allow write: if isExecutiveOrAbove();
    }

    // ----------------------------------------------------------------
    // Flow (legacy) — daily work
    // ----------------------------------------------------------------
    match /flow/{subcol}/{docId} {
      allow read, write: if isRPIUser();
    }

    // ----------------------------------------------------------------
    // ATLAS — leader+ writes
    // ----------------------------------------------------------------
    match /atlas/{subcol}/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }

    // ----------------------------------------------------------------
    // FORGE — Build Tracker (leader+ writes)
    // ----------------------------------------------------------------
    match /tracker_items/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
    match /sprints/{docId} {
      allow read: if isRPIUser();
      allow write: if isLeaderOrAbove();
    }
  }
}
