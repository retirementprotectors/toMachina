{
  "name": "@tomachina/core",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./atlas/*": {
      "types": "./src/atlas/*.ts",
      "default": "./dist/atlas/*.js"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./validation/*": {
      "types": "./src/validation/*.ts",
      "default": "./dist/validation/*.js"
    },
    "./api-types/*": {
      "types": "./src/api-types/*.ts",
      "default": "./dist/api-types/*.js"
    },
    "./schemas/*": {
      "types": "./src/schemas/*.ts",
      "default": "./dist/schemas/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "valibot": "^1.3.1"
  }
}
