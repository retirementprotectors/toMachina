{
  "name": "@tomachina/core",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./atlas/*": {
      "types": "./src/atlas/*.ts",
      "default": "./dist/atlas/*.js"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./validation/*": {
      "types": "./src/validation/*.ts",
      "default": "./dist/validation/*.js"
    },
    "./api-types/*": {
      "types": "./src/api-types/*.ts",
      "default": "./dist/api-types/*.js"
    },
    "./schemas/*": {
      "types": "./src/schemas/*.ts",
      "default": "./dist/schemas/*.js"
    },
    "./que/*": {
      "types": "./src/que/*.ts",
      "default": "./dist/que/*.js"
    },
    "./que/super-tools/*": {
      "types": "./src/que/super-tools/*.ts",
      "default": "./dist/que/super-tools/*.js"
    },
    "./que/wires/*": {
      "types": "./src/que/wires/*.ts",
      "default": "./dist/que/wires/*.js"
    },
    "./flow/*": {
      "types": "./src/flow/*.ts",
      "default": "./dist/flow/*.js"
    },
    "./notifications/*": {
      "types": "./src/notifications/*.ts",
      "default": "./dist/notifications/*.js"
    },
    "./matching/*": {
      "types": "./src/matching/*.ts",
      "default": "./dist/matching/*.js"
    },
    "./atlas/super-tools/*": {
      "types": "./src/atlas/super-tools/*.ts",
      "default": "./dist/atlas/super-tools/*.js"
    },
    "./voltron/*": {
      "types": "./src/voltron/*.ts",
      "default": "./dist/voltron/*.js"
    },
    "./voltron/super-tools/*": {
      "types": "./src/voltron/super-tools/*.ts",
      "default": "./dist/voltron/super-tools/*.js"
    },
    "./cmo/*": {
      "types": "./src/cmo/*.ts",
      "default": "./dist/cmo/*.js"
    },
    "./cmo/wires/*": {
      "types": "./src/cmo/wires/*.ts",
      "default": "./dist/cmo/wires/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "valibot": "^1.3.1"
  }
}
